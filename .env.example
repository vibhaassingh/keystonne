# Keystonne — environment template
# Copy to .env (gitignored) and fill in. Phase 1 needs only SESSION_SECRET.

# ─────────────────────────────────────────────────────────────────────────
# Phase 1 — required
# ─────────────────────────────────────────────────────────────────────────

# Used by Hydrogen to sign session cookies. Any non-empty string is fine in dev.
SESSION_SECRET="change-me-in-prod"

# ─────────────────────────────────────────────────────────────────────────
# Phase 1 — optional
# ─────────────────────────────────────────────────────────────────────────

# Storefront data source. Defaults to https://mock.shop in dev when unset.
# Phase 2: replace with a real Shopify storefront and Storefront API token.
# PUBLIC_STORE_DOMAIN="your-store.myshopify.com"
# PUBLIC_STOREFRONT_API_TOKEN=""
# PUBLIC_STOREFRONT_ID=""
# PUBLIC_CHECKOUT_DOMAIN=""

# ─────────────────────────────────────────────────────────────────────────
# Phase 2 — Supabase backend (partners, deals, commissions)
# Not used in Phase 1. Documented here so the .env shape is forward-compatible.
# ─────────────────────────────────────────────────────────────────────────

# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE=""   # server-side only

# ─────────────────────────────────────────────────────────────────────────
# Phase 3 — Zoho Books (commission invoicing, GST/TDS)
# ─────────────────────────────────────────────────────────────────────────

# ZOHO_BOOKS_ORG_ID=""
# ZOHO_BOOKS_CLIENT_ID=""
# ZOHO_BOOKS_CLIENT_SECRET=""
# ZOHO_BOOKS_REFRESH_TOKEN=""
